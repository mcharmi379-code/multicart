<sw-page class="multi-cart-manager-dashboard">
    <template #smart-bar-header>
        <h2>{{ $tc('multi-cart-manager.dashboard.title') }}</h2>
    </template>

    <template #smart-bar-actions>
        <div class="smart-bar-actions-container">
            <sw-select-field
                v-model="selectedSalesChannel"
                :label="$tc('multi-cart-manager.dashboard.salesChannel')"
                :options="salesChannels"
                option-value-key="id"
                option-label-key="name"
                @change="onSalesChannelChange"
                class="sales-channel-select"
            />
        </div>
    </template>

    <template #content>
        <sw-card-view>
        <!-- Analytics Cards -->
        <sw-card :title="$tc('multi-cart-manager.dashboard.analytics')" class="analytics-section">
            <div class="analytics-grid">
                <div class="analytics-card">
                    <div class="analytics-value">{{ analytics.totalCartsCreated || 0 }}</div>
                    <div class="analytics-label">{{ $tc('multi-cart-manager.dashboard.totalCarts') }}</div>
                </div>
                <div class="analytics-card">
                    <div class="analytics-value">{{ analytics.cartsConvertedToOrders || 0 }}</div>
                    <div class="analytics-label">{{ $tc('multi-cart-manager.dashboard.convertedOrders') }}</div>
                </div>
                <div class="analytics-card">
                    <div class="analytics-value">{{ analytics.conversionRate || 0 }}%</div>
                    <div class="analytics-label">{{ $tc('multi-cart-manager.dashboard.conversionRate') }}</div>
                </div>
                <div class="analytics-card">
                    <div class="analytics-value">{{ analytics.averageItemsPerCart || 0 }}</div>
                    <div class="analytics-label">{{ $tc('multi-cart-manager.dashboard.avgItems') }}</div>
                </div>
                <div class="analytics-card">
                    <div class="analytics-value">€ {{ analytics.averageCartValue || 0 }}</div>
                    <div class="analytics-label">{{ $tc('multi-cart-manager.dashboard.avgValue') }}</div>
                </div>
                <div class="analytics-card">
                    <div class="analytics-value">€ {{ analytics.totalCartValue || 0 }}</div>
                    <div class="analytics-label">{{ $tc('multi-cart-manager.dashboard.totalValue') }}</div>
                </div>
            </div>
        </sw-card>

        <!-- Active Carts -->
        <sw-card :title="$tc('multi-cart-manager.dashboard.activeCarts')" class="active-carts-section">
            <sw-data-grid
                :data-source="activeCarts"
                :columns="activeCartsColumns"
                :show-selection="false"
                :is-loading="isLoading"
            >
                <template #column-name="{ item }">
                    <span>{{ item.name }}</span>
                </template>
                <template #column-owner="{ item }">
                    <span>{{ item.owner }}</span>
                </template>
                <template #column-itemCount="{ item }">
                    <span>{{ item.itemCount }}</span>
                </template>
                <template #column-total="{ item }">
                    <span>€ {{ item.total }}</span>
                </template>
                <template #column-lastActivity="{ item }">
                    <span>{{ item.lastActivity | date }}</span>
                </template>
            </sw-data-grid>
        </sw-card>

        <!-- Completed Orders -->
        <sw-card :title="$tc('multi-cart-manager.dashboard.completedOrders')" class="completed-orders-section">
            <sw-data-grid
                :data-source="completedOrders"
                :columns="completedOrdersColumns"
                :show-selection="false"
                :is-loading="isLoading"
            >
                <template #column-cartName="{ item }">
                    <span>{{ item.cartName }}</span>
                </template>
                <template #column-orderId="{ item }">
                    <span>{{ item.orderId }}</span>
                </template>
                <template #column-promotionCode="{ item }">
                    <span>{{ item.promotionCode || '-' }}</span>
                </template>
                <template #column-discount="{ item }">
                    <span>€ {{ item.discount || 0 }}</span>
                </template>
                <template #column-orderedAt="{ item }">
                    <span>{{ item.orderedAt | date }}</span>
                </template>
            </sw-data-grid>
        </sw-card>
        </sw-card-view>
    </template>
</sw-page>
