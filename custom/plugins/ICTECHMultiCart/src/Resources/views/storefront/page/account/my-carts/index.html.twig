{% sw_extends '@Storefront/storefront/page/account/_page.html.twig' %}

{% set multiCartState = page.state %}
{% set carts = page.carts %}
{% set combinedCheckoutEnabled = multiCartState.checkoutPrefsEnabled and multiCartState.multiPaymentEnabled %}

{% block page_account_main_content %}
    <div class="ictech-account-carts"
         data-ictech-multi-cart-account="true"
         data-ictech-preferences-url-template="{{ path('frontend.ictech.multi_cart.account.preferences', { cartId: '__cartId__' }) }}"
         data-ictech-promotion-url-template="{{ path('frontend.ictech.multi_cart.account.promotion', { cartId: '__cartId__' }) }}"
         data-ictech-rename-url-template="{{ path('frontend.ictech.multi_cart.account.rename', { cartId: '__cartId__' }) }}"
         data-ictech-address-url="{{ path('frontend.ictech.multi_cart.account.address.create') }}"
         data-ictech-combined-url="{{ path('frontend.ictech.multi_cart.account.combined_checkout') }}"
         data-ictech-combined-mismatch-label="{{ 'ictech-multi-cart.account.combined.mismatchIntro'|trans }}"
         data-ictech-promo-apply-label="{{ 'ictech-multi-cart.account.promoApply'|trans }}"
         data-ictech-promo-applied-label="{{ 'ictech-multi-cart.account.promoApplied'|trans }}"
         data-ictech-promo-saved-label="{{ 'ictech-multi-cart.account.promoSaved'|trans }}"
         data-ictech-promo-removed-label="{{ 'ictech-multi-cart.account.promoRemoved'|trans }}"
         data-ictech-promo-failed-label="{{ 'ictech-multi-cart.account.promoApplyFailed'|trans }}"
         data-ictech-combined-enabled="{{ combinedCheckoutEnabled ? 'true' : 'false' }}"
         data-ictech-combined-disabled-label="{{ 'ictech-multi-cart.account.combined.disabledMessage'|trans }}">
        {% sw_include '@ICTECHMultiCart/storefront/page/account/my-carts/_hero.html.twig' %}

        {% if carts is empty %}
            <div class="ictech-account-carts__empty">
                {{ 'ictech-multi-cart.account.empty'|trans }}
            </div>
        {% else %}
            <section class="ictech-account-carts__grid">
                {% for cart in carts %}
                    {% sw_include '@ICTECHMultiCart/storefront/page/account/my-carts/_cart-card.html.twig' with {
                        cart: cart
                    } %}
                {% endfor %}
            </section>

            {% if combinedCheckoutEnabled %}
            <div class="ictech-account-carts__combined-bar" hidden data-ictech-combined-bar>
                <div>
                    <strong data-ictech-combined-count>0</strong>
                    <span>{{ 'ictech-multi-cart.account.combined.selectedSuffix'|trans }}</span>
                    <strong data-ictech-combined-total>0.00</strong>
                </div>
                    <button type="button" class="ictech-account-carts__btn ictech-account-carts__btn--primary" data-ictech-combined-open>
                        {{ 'ictech-multi-cart.account.combined.paySelected'|trans }}
                    </button>
            </div>
            {% endif %}
        {% endif %}

        <form method="post" action="{{ path('frontend.ictech.multi_cart.account.create') }}" class="ictech-account-carts__modal" hidden data-ictech-create-modal>
            <div class="ictech-account-carts__modal-dialog">
                <h3>{{ 'ictech-multi-cart.account.createButton'|trans }}</h3>
                {% set createUnavailable = not multiCartState.canCreateCart %}
                <input class="ictech-account-carts__input"
                       type="text"
                       name="name"
                       maxlength="255"
                       placeholder="{{ 'ictech-multi-cart.account.createPlaceholder'|trans }}"
                       {% if createUnavailable %}disabled{% endif %}>
                {% if createUnavailable %}
                    <p class="mb-0">
                        {% if multiCartState.createCartReason == 'limit_reached' %}
                            {{ 'ictech-multi-cart.account.createLimitReached'|trans({'%limit%': multiCartState.maxCartsPerUser}) }}
                        {% else %}
                            {{ 'ictech-multi-cart.account.createUnavailable'|trans }}
                        {% endif %}
                    </p>
                {% endif %}
                <div class="ictech-account-carts__modal-actions">
                    <button type="button" class="ictech-account-carts__btn ictech-account-carts__btn--ghost" data-ictech-modal-close>{{ 'ictech-multi-cart.account.cancel'|trans }}</button>
                    <button type="submit"
                            class="ictech-account-carts__btn ictech-account-carts__btn--primary"
                            {% if createUnavailable %}disabled{% endif %}>{{ 'ictech-multi-cart.account.createButton'|trans }}</button>
                </div>
            </div>
        </form>

        <form class="ictech-account-carts__modal" hidden data-ictech-address-modal>
            <div class="ictech-account-carts__modal-dialog">
                <h3>{{ 'ictech-multi-cart.account.addressModalTitle'|trans }}</h3>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.addressFirstName'|trans }}</label>
                    <input class="ictech-account-carts__input" type="text" name="firstName" required>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.addressLastName'|trans }}</label>
                    <input class="ictech-account-carts__input" type="text" name="lastName" required>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.addressStreet'|trans }}</label>
                    <input class="ictech-account-carts__input" type="text" name="street" required>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.addressZipcode'|trans }}</label>
                    <input class="ictech-account-carts__input" type="text" name="zipcode" required>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.addressCity'|trans }}</label>
                    <input class="ictech-account-carts__input" type="text" name="city" required>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.addressCountry'|trans }}</label>
                    <select class="ictech-account-carts__select" name="countryId" required>
                        {% for country in page.options.countries %}
                            <option value="{{ country.id }}">{{ country.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <input type="hidden" name="cartId" value="" data-ictech-address-cart-id>
                <input type="hidden" name="targetField" value="" data-ictech-address-target-field>
                <p class="ictech-account-carts__promo-feedback" hidden data-ictech-address-feedback></p>
                <div class="ictech-account-carts__modal-actions">
                    <button type="button" class="ictech-account-carts__btn ictech-account-carts__btn--ghost" data-ictech-modal-close>{{ 'ictech-multi-cart.account.cancel'|trans }}</button>
                    <button type="submit" class="ictech-account-carts__btn ictech-account-carts__btn--primary">{{ 'ictech-multi-cart.account.addressCreate'|trans }}</button>
                </div>
            </div>
        </form>

        {% if combinedCheckoutEnabled %}
        <form method="post" action="{{ path('frontend.ictech.multi_cart.account.combined_checkout') }}" class="ictech-account-carts__modal" hidden data-ictech-combined-modal data-ictech-combined-form>
            <div class="ictech-account-carts__modal-dialog">
                <h3>{{ 'ictech-multi-cart.account.combined.title'|trans }}</h3>
                <p data-ictech-combined-description>{{ 'ictech-multi-cart.account.combined.description'|trans }}</p>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.shippingAddress'|trans }}</label>
                    <select class="ictech-account-carts__select" name="shippingAddressId" data-ictech-combined-field="shippingAddressId">
                        {% for address in page.options.addresses %}
                            <option value="{{ address.id }}">{{ address.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.billingAddress'|trans }}</label>
                    <select class="ictech-account-carts__select" name="billingAddressId" data-ictech-combined-field="billingAddressId">
                        {% for address in page.options.addresses %}
                            <option value="{{ address.id }}">{{ address.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.paymentMethod'|trans }}</label>
                    <select class="ictech-account-carts__select" name="paymentMethodId" data-ictech-combined-field="paymentMethodId">
                        {% for method in page.options.paymentMethods %}
                            <option value="{{ method.id }}">{{ method.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="ictech-account-carts__field">
                    <label>{{ 'ictech-multi-cart.account.shippingMethod'|trans }}</label>
                    <select class="ictech-account-carts__select" name="shippingMethodId" data-ictech-combined-field="shippingMethodId">
                        {% for method in page.options.shippingMethods %}
                            <option value="{{ method.id }}">{{ method.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div data-ictech-combined-cart-ids></div>
                <div class="ictech-account-carts__modal-actions">
                    <button type="button" class="ictech-account-carts__btn ictech-account-carts__btn--ghost" data-ictech-modal-close>{{ 'ictech-multi-cart.account.cancel'|trans }}</button>
                    <button type="submit" class="ictech-account-carts__btn ictech-account-carts__btn--primary">{{ 'ictech-multi-cart.account.combined.completeOrder'|trans }}</button>
                </div>
            </div>
        </form>
        {% endif %}
    </div>

    {% sw_include '@ICTECHMultiCart/storefront/page/account/my-carts/_scripts.html.twig' %}
{% endblock %}
