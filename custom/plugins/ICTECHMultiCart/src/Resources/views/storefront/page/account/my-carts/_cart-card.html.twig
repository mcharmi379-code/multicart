<article class="ictech-account-carts__card{% if cart.isActive %} is-active{% endif %}" data-cart-id="{{ cart.id }}">
    <div class="ictech-account-carts__card-header">
        <div class="ictech-account-carts__title-wrap">
            <div class="ictech-account-carts__title-row">
                <h2 class="ictech-account-carts__card-title" data-ictech-cart-title>{{ cart.name }}</h2>
                <button type="button"
                        class="ictech-account-carts__edit-name"
                        data-ictech-rename-toggle
                        aria-label="{{ 'ictech-multi-cart.account.renameButton'|trans|striptags }}">
                    {% sw_icon 'pencil' style { size: 'sm', ariaHidden: true } %}
                    <span>{{ 'ictech-multi-cart.account.renameButton'|trans }}</span>
                </button>
            </div>
            <form class="ictech-account-carts__rename-form" hidden data-ictech-rename-form>
                <p class="ictech-account-carts__rename-hint">{{ 'ictech-multi-cart.account.renameHint'|trans }}</p>
                <input type="text"
                       class="ictech-account-carts__input"
                       name="name"
                       maxlength="255"
                       value="{{ cart.name }}"
                       data-ictech-rename-input
                       aria-label="{{ 'ictech-multi-cart.account.renameLabel'|trans|striptags }}">
                <div class="ictech-account-carts__rename-actions">
                    <button type="submit" class="ictech-account-carts__btn ictech-account-carts__btn--primary" data-ictech-rename-save>
                        {{ 'ictech-multi-cart.account.renameSave'|trans }}
                    </button>
                    <button type="button" class="ictech-account-carts__btn ictech-account-carts__btn--ghost" data-ictech-rename-cancel>
                        {{ 'ictech-multi-cart.account.cancel'|trans }}
                    </button>
                </div>
                <p class="ictech-account-carts__rename-feedback" hidden data-ictech-rename-feedback></p>
            </form>
            <div class="ictech-account-carts__date">{{ cart.updatedAt ?: cart.createdAt }}</div>
        </div>

        <div class="ictech-account-carts__toolbar">
            {% if cart.isActive %}
                <span class="ictech-account-carts__chip">{{ 'ictech-multi-cart.account.active'|trans }}</span>
            {% endif %}

            <form method="post" action="{{ path('frontend.ictech.multi_cart.account.view', { cartId: cart.id }) }}" class="ictech-account-carts__icon-form">
                <button type="submit" class="ictech-account-carts__icon-btn" title="{{ 'ictech-multi-cart.account.viewCart'|trans|striptags }}">
                    {% sw_icon 'eye-open' style { size: 'sm', ariaHidden: true } %}
                </button>
            </form>
            <form method="post" action="{{ path('frontend.ictech.multi_cart.account.checkout', { cartId: cart.id }) }}" class="ictech-account-carts__icon-form">
                <button type="submit" class="ictech-account-carts__icon-btn ictech-account-carts__icon-btn--primary" title="{{ 'ictech-multi-cart.account.checkout'|trans|striptags }}">
                    {% sw_icon 'bag' style { size: 'sm', ariaHidden: true } %}
                </button>
            </form>
            <form method="post" action="{{ path('frontend.ictech.multi_cart.account.duplicate', { cartId: cart.id }) }}" class="ictech-account-carts__icon-form">
                <button type="submit" class="ictech-account-carts__icon-btn" title="{{ 'ictech-multi-cart.account.duplicate'|trans|striptags }}">
                    {% sw_icon 'arrow-switch' style { size: 'sm', ariaHidden: true } %}
                </button>
            </form>
            {% if not cart.isDefault %}
                <form method="post" action="{{ path('frontend.ictech.multi_cart.account.delete', { cartId: cart.id }) }}" class="ictech-account-carts__icon-form">
                    <button type="submit" class="ictech-account-carts__icon-btn ictech-account-carts__icon-btn--danger" title="{{ 'ictech-multi-cart.account.delete'|trans|striptags }}">
                        {% sw_icon 'trash' style { size: 'sm', ariaHidden: true } %}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    <div class="ictech-account-carts__meta">
        <div>
            <span>{{ 'ictech-multi-cart.account.itemsLabel'|trans }}</span>
            <strong>{{ cart.itemCount }}</strong>
        </div>
        <div>
            <span>{{ 'ictech-multi-cart.account.subtotalLabel'|trans }}</span>
            <strong data-ictech-cart-subtotal>{{ cart.subtotal|currency(cart.currencyIso) }}</strong>
        </div>
        {% if cart.promotionDiscount > 0 %}
            <div data-ictech-cart-discount-row>
                <span>{{ 'ictech-multi-cart.account.discountLabel'|trans }}</span>
                <strong data-ictech-cart-discount>-{{ cart.promotionDiscount|currency(cart.currencyIso) }}</strong>
            </div>
        {% else %}
            <div hidden data-ictech-cart-discount-row>
                <span>{{ 'ictech-multi-cart.account.discountLabel'|trans }}</span>
                <strong data-ictech-cart-discount></strong>
            </div>
        {% endif %}
        <div>
            <span>{{ 'ictech-multi-cart.account.totalLabel'|trans }}</span>
            <strong data-ictech-cart-total-display>{{ cart.total|currency(cart.currencyIso) }}</strong>
        </div>
        <div>
            <span>{{ 'ictech-multi-cart.account.statusLabel'|trans }}</span>
            <strong>{{ cart.status|capitalize }}</strong>
        </div>
    </div>

    <div class="ictech-account-carts__field">
        <label>{{ 'ictech-multi-cart.account.shippingAddress'|trans }}</label>
        <select class="ictech-account-carts__select"
                data-ictech-preference="shippingAddressId"
                data-cart-id="{{ cart.id }}">
            <option value="">{{ 'ictech-multi-cart.account.selectPlaceholder'|trans }}</option>
            {% for address in page.options.addresses %}
                <option value="{{ address.id }}"{% if address.id == cart.shippingAddressId %} selected{% endif %}>{{ address.label }}</option>
            {% endfor %}
        </select>
        <a href="{{ path('frontend.account.address.create.page', { redirectTo: 'frontend.ictech.multi_cart.account.page' }) }}"
           class="ictech-account-carts__helper-link"
           data-ictech-add-address
           data-ictech-address-target="shippingAddressId">
            {{ 'ictech-multi-cart.account.addNewAddress'|trans }}
        </a>
    </div>

    <div class="ictech-account-carts__field">
        <label>{{ 'ictech-multi-cart.account.billingAddress'|trans }}</label>
        <label class="ictech-account-carts__combined">
            <input type="checkbox"
                   value="1"
                   {% if cart.billingAddressId and cart.billingAddressId == cart.shippingAddressId %}checked{% endif %}
                   data-ictech-same-as-shipping>
            <span>{{ 'ictech-multi-cart.account.sameAsShipping'|trans }}</span>
        </label>
        <select class="ictech-account-carts__select"
                data-ictech-preference="billingAddressId"
                data-cart-id="{{ cart.id }}">
            <option value="">{{ 'ictech-multi-cart.account.selectPlaceholder'|trans }}</option>
            {% for address in page.options.addresses %}
                <option value="{{ address.id }}"{% if address.id == cart.billingAddressId %} selected{% endif %}>{{ address.label }}</option>
            {% endfor %}
        </select>
        <a href="{{ path('frontend.account.address.create.page', { redirectTo: 'frontend.ictech.multi_cart.account.page' }) }}"
           class="ictech-account-carts__helper-link"
           data-ictech-add-address
           data-ictech-address-target="billingAddressId">
            {{ 'ictech-multi-cart.account.addNewAddress'|trans }}
        </a>
    </div>

    <div class="ictech-account-carts__field">
        <label>{{ 'ictech-multi-cart.account.paymentMethod'|trans }}</label>
        <select class="ictech-account-carts__select"
                data-ictech-preference="paymentMethodId"
                data-cart-id="{{ cart.id }}">
            {% for method in page.options.paymentMethods %}
                <option value="{{ method.id }}"{% if method.id == cart.paymentMethodId %} selected{% endif %}>{{ method.name }}</option>
            {% endfor %}
        </select>
    </div>

    <div class="ictech-account-carts__field">
        <label>{{ 'ictech-multi-cart.account.shippingMethod'|trans }}</label>
        <select class="ictech-account-carts__select"
                data-ictech-preference="shippingMethodId"
                data-cart-id="{{ cart.id }}">
            {% for method in page.options.shippingMethods %}
                <option value="{{ method.id }}"{% if method.id == cart.shippingMethodId %} selected{% endif %}>{{ method.name }}</option>
            {% endfor %}
        </select>
    </div>

    {% if page.state.promotionsEnabled %}
        <div class="ictech-account-carts__field">
            <label>{{ 'ictech-multi-cart.account.promoCode'|trans }}</label>
            <div class="ictech-account-carts__promo-row">
                <input class="ictech-account-carts__input"
                       type="text"
                       value="{{ cart.promotionCode ?? '' }}"
                       placeholder="{{ 'ictech-multi-cart.account.promoPlaceholder'|trans }}"
                       data-ictech-promotion-input
                       data-cart-id="{{ cart.id }}">
                <button type="button"
                        class="ictech-account-carts__btn ictech-account-carts__btn--ghost"
                        data-ictech-promotion-apply
                        data-cart-id="{{ cart.id }}">
                    {{ 'ictech-multi-cart.account.promoApply'|trans }}
                </button>
                <button type="button"
                        class="ictech-account-carts__btn ictech-account-carts__btn--ghost"
                        data-ictech-promotion-remove
                        data-cart-id="{{ cart.id }}">
                    {{ 'ictech-multi-cart.account.promoRemove'|trans }}
                </button>
            </div>
            <p class="ictech-account-carts__promo-feedback" hidden data-ictech-promotion-feedback></p>
        </div>
    {% endif %}

    <ul class="ictech-account-carts__items">
        {% for item in cart.items|slice(0, 3) %}
            <li class="ictech-account-carts__item">
                <span>
                    <strong>{{ item.productName }}</strong>
                    {{ item.productNumber }} x{{ item.quantity }}
                </span>
                <span>{{ item.totalPrice|currency(cart.currencyIso) }}</span>
            </li>
        {% else %}
            <li class="ictech-account-carts__item">
                <span>{{ 'ictech-multi-cart.account.noProducts'|trans }}</span>
            </li>
        {% endfor %}
    </ul>

    {% if page.state.checkoutPrefsEnabled %}
        <label class="ictech-account-carts__combined">
            <input type="checkbox"
                   value="{{ cart.id }}"
                   data-ictech-combined-cart
                   data-ictech-cart-total="{{ cart.total }}"
                   data-ictech-cart-name="{{ cart.name }}"
                   data-cart-id="{{ cart.id }}"
                   {% if not page.state.multiPaymentEnabled %}disabled{% endif %}>
            <span>{{ 'ictech-multi-cart.account.combined.selectLabel'|trans }}</span>
        </label>
        {% if not page.state.multiPaymentEnabled %}
            <p class="ictech-account-carts__combined-note">{{ 'ictech-multi-cart.account.combined.disabledMessage'|trans }}</p>
        {% endif %}
    {% endif %}
</article>
