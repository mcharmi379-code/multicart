<script>
(() => {
    if (window.ICTECHMultiCartInlineLoaded) {
        return;
    }

    window.ICTECHMultiCartInlineLoaded = true;

    const rootClass = 'ictech-multi-cart-inline';
    let activeOverlay = null;
    let activeDialog = null;
    let activeContext = null;

    const escapeHtml = (value) => {
        const div = document.createElement('div');
        div.textContent = value == null ? '' : String(value);
        return div.innerHTML;
    };

    const parseLabels = (form) => {
        try {
            return JSON.parse(form.getAttribute('data-multi-cart-labels') || '{}');
        } catch (error) {
            return {};
        }
    };

    const formatPrice = (value, currencyIso) => `${Number(value || 0).toFixed(2)} ${currencyIso || 'EUR'}`;

    const getPayload = (form) => {
        const formData = new FormData(form);
        let productId = '';
        let quantity = 1;

        for (const [key, value] of formData.entries()) {
            if (key.endsWith('[referencedId]') && typeof value === 'string') {
                productId = value;
            }

            if (key.endsWith('[quantity]') && typeof value === 'string') {
                quantity = Number.parseInt(value, 10) || 1;
            }
        }

        return {
            productId,
            quantity,
            productName: typeof formData.get('product-name') === 'string' ? formData.get('product-name') : '',
        };
    };

    const ensureStyles = () => {
        if (document.getElementById('ictech-multi-cart-inline-style')) {
            return;
        }

        const style = document.createElement('style');
        style.id = 'ictech-multi-cart-inline-style';
        style.textContent = `
            .${rootClass}-overlay{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;padding:1rem;background:rgba(12,18,28,.54);backdrop-filter:blur(5px);z-index:1061}
            .${rootClass}-overlay[data-ui-style="drawer"]{justify-content:flex-end;padding:0}
            .${rootClass}{width:min(960px,100%);max-height:min(88vh,860px);overflow:auto;border-radius:28px;background:linear-gradient(180deg,#fcfdff 0,#f4f8ff 100%);box-shadow:0 30px 80px rgba(12,30,66,.24);color:#14243d}
            .${rootClass}-overlay[data-ui-style="drawer"] .${rootClass}{width:min(430px,100vw);height:100vh;max-height:100vh;border-radius:0}
            .${rootClass}__shell{padding:1.25rem}
            .${rootClass}__hero{padding:1.4rem;border-radius:24px;background:radial-gradient(circle at top right,rgba(10,86,198,.17),transparent 32%),linear-gradient(135deg,#f8fbff 0,#fff 55%,#edf4ff 100%)}
            .${rootClass}__eyebrow{margin:0 0 .5rem;font-size:.72rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#0a56c6}
            .${rootClass}__title{margin:0;font-size:clamp(1.4rem,2.3vw,2rem);font-weight:800;line-height:1.1}
            .${rootClass}__subtitle{margin:.65rem 0 0;color:#5a6980}
            .${rootClass}__close{position:absolute;top:1rem;right:1rem;width:42px;height:42px;border:0;border-radius:50%;background:#fff;box-shadow:0 12px 28px rgba(12,30,66,.14);font-size:1.3rem;cursor:pointer}
            .${rootClass}__layout{display:grid;grid-template-columns:minmax(0,.95fr) minmax(0,1.05fr);gap:1rem;margin-top:1rem}
            .${rootClass}-overlay[data-ui-style="drawer"] .${rootClass}__layout{grid-template-columns:1fr}
            .${rootClass}__panel{padding:1.1rem;border:1px solid #d8e3ef;border-radius:22px;background:#fff;box-shadow:0 18px 40px rgba(12,30,66,.08)}
            .${rootClass}__panel--accent{background:linear-gradient(180deg,#fff 0,#f7faff 100%)}
            .${rootClass}__section-head{display:flex;align-items:center;justify-content:space-between;gap:.75rem;margin-bottom:.9rem}
            .${rootClass}__section-head h3,.${rootClass}__section-head h4{margin:0;font-size:1rem;font-weight:800}
            .${rootClass}__section-head span{color:#5a6980}
            .${rootClass}__cards,.${rootClass}__items{display:grid;gap:.75rem}
            .${rootClass}__card{width:100%;padding:1rem;border:1px solid #d8e3ef;border-radius:18px;background:#f8fbff;text-align:left;cursor:pointer}
            .${rootClass}__card.is-active{border-color:#0a56c6;background:#eef5ff}
            .${rootClass}__card-name{display:block;font-weight:800}
            .${rootClass}__card-meta{display:block;margin-top:.25rem;color:#5a6980;font-size:.92rem}
            .${rootClass}__item{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:.75rem;align-items:center;padding-bottom:.65rem;border-bottom:1px solid #e6edf5}
            .${rootClass}__item:last-child{padding-bottom:0;border-bottom:0}
            .${rootClass}__summary{margin-top:1rem;padding-top:1rem;border-top:1px solid #e6edf5}
            .${rootClass}__summary-row{display:flex;align-items:center;justify-content:space-between;font-weight:700}
            .${rootClass}__pending{padding:.9rem 1rem;border-radius:18px;background:#edf4ff;border:1px solid rgba(10,86,198,.14)}
            .${rootClass}__pending span{display:block;color:#5a6980;font-size:.9rem}
            .${rootClass}__pending strong{display:block;margin-top:.2rem}
            .${rootClass}__input,.${rootClass}__select{width:100%;min-height:46px;padding:.78rem .9rem;border:1px solid #d8e3ef;border-radius:14px;background:#fff}
            .${rootClass}__toolbar,.${rootClass}__actions,.${rootClass}__create{display:grid;gap:.75rem}
            .${rootClass}__promo,.${rootClass}__create{grid-template-columns:minmax(0,1fr) auto;align-items:center}
            .${rootClass}__promo-actions{display:grid;gap:.55rem;grid-template-columns:repeat(2,minmax(0,1fr));align-items:center}
            .${rootClass}__actions{grid-template-columns:repeat(3,minmax(0,1fr));margin-top:1rem}
            .${rootClass}__primary,.${rootClass}__secondary,.${rootClass}__ghost{min-height:44px;padding:.8rem 1rem;border-radius:999px;font-weight:800;cursor:pointer}
            .${rootClass}__primary{width:100%;margin-top:1rem;border:0;background:linear-gradient(135deg,#0a56c6 0,#083c8d 100%);color:#fff}
            .${rootClass}__secondary{border:0;background:#edf4ff;color:#0a3d8d}
            .${rootClass}__ghost{border:1px solid #d8e3ef;background:#fff;color:#0a3d8d}
            .${rootClass}__ghost--subtle{background:#f8fbff}
            .${rootClass}__feedback{min-height:1.35rem;margin-top:.85rem;font-weight:700}
            .${rootClass}__feedback.is-error{color:#c0392b}
            .${rootClass}__feedback.is-success{color:#1c7c48}
            .${rootClass}__empty{color:#5a6980}
            @media (max-width: 991.98px){.${rootClass}__layout{grid-template-columns:1fr}}
            @media (max-width: 767.98px){.${rootClass}{width:100%;border-radius:22px}.${rootClass}-overlay{padding:.5rem}.${rootClass}-overlay[data-ui-style="drawer"]{padding:0}.${rootClass}__shell{padding:1rem}.${rootClass}__promo,.${rootClass}__create,.${rootClass}__actions,.${rootClass}__promo-actions{grid-template-columns:1fr}}
        `;

        document.head.appendChild(style);
    };

    const closeDialog = () => {
        if (activeOverlay) {
            activeOverlay.remove();
        }

        activeOverlay = null;
        activeDialog = null;
        activeContext = null;
        document.documentElement.classList.remove('is-ictech-multi-cart-open');
    };

    const request = async (url, body) => {
        const response = await fetch(url, {
            method: body ? 'POST' : 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
            },
            body,
        });

        const data = await response.json().catch(() => null);

        if (!response.ok) {
            throw new Error(data && data.message ? data.message : `Request failed with ${response.status}`);
        }

        return data;
    };

    const getSelectedCart = (state, selectedCartId) => {
        const carts = Array.isArray(state && state.carts) ? state.carts : [];
        return carts.find((cart) => cart.id === selectedCartId) || carts[0] || null;
    };

    const renderItems = (state, selectedCart) => {
        const labels = activeContext.labels;
        const items = Array.isArray(selectedCart && selectedCart.items) ? selectedCart.items : [];

        if (items.length === 0) {
            return `<p class="${rootClass}__empty">${escapeHtml(labels.cartProductsEmptyLabel || 'No products in this cart yet.')}</p>`;
        }

        return `<div class="${rootClass}__items">${items.map((item) => `
            <div class="${rootClass}__item">
                <div>
                    <strong>${escapeHtml(item.productName || labels.productFallbackLabel || 'Product')}</strong>
                    <div>${escapeHtml(`${item.productNumber || ''} x${Number(item.quantity || 0)}`.trim())}</div>
                </div>
                <span>${escapeHtml(formatPrice(item.totalPrice, selectedCart.currencyIso))}</span>
            </div>
        `).join('')}</div>`;
    };

    const renderPromotionSummary = (selectedCart) => {
        const labels = activeContext.labels;
        const promotionCode = selectedCart && selectedCart.promotionCode ? String(selectedCart.promotionCode).trim() : '';
        const promotionDiscount = Number(selectedCart && selectedCart.promotionDiscount ? selectedCart.promotionDiscount : 0);

        if (!promotionCode && promotionDiscount <= 0) {
            return '';
        }

        const currencyIso = selectedCart && selectedCart.currencyIso ? selectedCart.currencyIso : 'EUR';
        const summaryRows = [];

        summaryRows.push(`
            <div class="${rootClass}__summary-row">
                <span>${escapeHtml(labels.promoCodeLabel || labels.promoCode || 'Promo code')}</span>
                <strong>${escapeHtml(promotionCode || '-')}</strong>
            </div>
        `);

        if (promotionDiscount > 0) {
            summaryRows.push(`
                <div class="${rootClass}__summary-row">
                    <span>${escapeHtml(labels.discountLabel || 'Discount')}</span>
                    <strong>-${escapeHtml(formatPrice(promotionDiscount, currencyIso))}</strong>
                </div>
            `);
        }

        return summaryRows.join('');
    };

    const renderDialog = () => {
        const { state, payload, labels } = activeContext;
        const carts = Array.isArray(state.carts) ? state.carts : [];
        const selectedCart = getSelectedCart(state, activeContext.selectedCartId);
        const uiStyle = state.uiStyle === 'drawer' ? 'drawer' : 'popup';
        const createDisabledMessage = !state.canCreateCart
            ? (state.createCartReason === 'limit_reached'
                ? (labels.createDisabledLimitLabel || 'You have reached the maximum number of carts.')
                : (labels.createDisabledUnavailableLabel || 'Cart creation is currently unavailable.'))
            : '';
        const promotionValue = selectedCart && selectedCart.promotionCode ? selectedCart.promotionCode : '';
        const promotionControls = state.promotionsEnabled ? `
            <div class="${rootClass}__promo" style="margin-top:1rem">
                <input class="${rootClass}__input" type="text" value="${escapeHtml(promotionValue)}" placeholder="${escapeHtml(labels.promoPlaceholder || 'Promo code (global discount)')}" data-ictech-promo-input>
                <div class="${rootClass}__promo-actions">
                    <button type="button" class="${rootClass}__ghost" data-ictech-promo-apply>${escapeHtml(labels.promoApplyLabel || 'Apply')}</button>
                    <button type="button" class="${rootClass}__ghost ${rootClass}__ghost--subtle" data-ictech-promo-remove>${escapeHtml(labels.promoRemoveLabel || 'Remove')}</button>
                </div>
            </div>
        ` : '';
        const promotionSummary = renderPromotionSummary(selectedCart);
        const cartOptions = carts.map((cart) => `<option value="${escapeHtml(cart.id)}"${cart.id === activeContext.selectedCartId ? ' selected' : ''}>${escapeHtml(cart.name)}</option>`).join('');
        const cards = carts.length === 0
            ? `<p class="${rootClass}__empty">${escapeHtml(labels.noCartsLabel || 'No carts yet. Create your first cart below.')}</p>`
            : `<div class="${rootClass}__cards">${carts.map((cart) => `
                <button type="button" class="${rootClass}__card${cart.id === activeContext.selectedCartId ? ' is-active' : ''}" data-ictech-cart-select="${escapeHtml(cart.id)}">
                    <span class="${rootClass}__card-name">${escapeHtml(cart.name)}</span>
                    <span class="${rootClass}__card-meta">${escapeHtml(`${Number(cart.itemCount || 0)} ${labels.itemsLabel || 'items'} • ${formatPrice(cart.total, cart.currencyIso)}`)}</span>
                </button>
            `).join('')}</div>`;

        activeOverlay.dataset.uiStyle = uiStyle;
        activeDialog.innerHTML = `
            <div class="${rootClass}__shell">
                <button type="button" class="${rootClass}__close" data-ictech-close aria-label="Close">&times;</button>
                <section class="${rootClass}__hero">
                    <p class="${rootClass}__eyebrow">${escapeHtml(labels.selectorEyebrow || 'Multi Cart')}</p>
                    <h2 class="${rootClass}__title">${escapeHtml(uiStyle === 'drawer' ? (labels.selectorDrawerTitle || 'Your cart') : (labels.selectorTitle || 'Choose a cart'))}</h2>
                    <p class="${rootClass}__subtitle">${escapeHtml(labels.selectorSubtitle || 'Add this product to one of your carts or create a new one instantly.')}</p>
                </section>
                <div class="${rootClass}__layout">
                    <section class="${rootClass}__panel">
                        <div class="${rootClass}__section-head">
                            <h3>${escapeHtml(labels.existingCartsLabel || 'Your carts')}</h3>
                            <span>${escapeHtml(String(state.cartCount || carts.length || 0))}</span>
                        </div>
                        ${uiStyle === 'drawer' ? `
                            <div class="${rootClass}__toolbar">
                                <select class="${rootClass}__select" data-ictech-cart-dropdown>${cartOptions}</select>
                            </div>
                        ` : cards}
                        <div class="${rootClass}__create" style="margin-top:1rem">
                            <input class="${rootClass}__input" type="text" maxlength="255" placeholder="${escapeHtml(labels.cartNamePlaceholder || 'For example: March office order')}" data-ictech-cart-name${state.canCreateCart ? '' : ' disabled'}>
                            <button type="button" class="${rootClass}__secondary" data-ictech-create-cart>${escapeHtml(labels.createAndAddLabel || 'Create and add product')}</button>
                        </div>
                        ${createDisabledMessage ? `<p class="${rootClass}__subtitle">${escapeHtml(createDisabledMessage)}</p>` : ''}
                    </section>
                    <section class="${rootClass}__panel ${rootClass}__panel--accent">
                        <div class="${rootClass}__section-head">
                            <h4>${escapeHtml(labels.orderSummaryLabel || 'Order summary')}</h4>
                            <span>${escapeHtml(selectedCart ? selectedCart.name : (labels.cartFallbackLabel || 'cart'))}</span>
                        </div>
                        <div class="${rootClass}__pending">
                            <span>${escapeHtml(labels.pendingProductLabel || 'Ready to add')}</span>
                            <strong>${escapeHtml(payload.productName || labels.productFallbackLabel || 'Product')}</strong>
                        </div>
                        <div style="margin-top:1rem">
                            <div class="${rootClass}__section-head">
                                <h4>${escapeHtml(labels.cartProductsLabel || 'Products in this cart')}</h4>
                            </div>
                            ${renderItems(state, selectedCart)}
                        </div>
                        <div class="${rootClass}__summary">
                            <div class="${rootClass}__summary-row">
                                <span>${escapeHtml(labels.subtotalLabel || 'Subtotal')}</span>
                                <strong>${escapeHtml(formatPrice(selectedCart ? selectedCart.subtotal : 0, selectedCart ? selectedCart.currencyIso : 'EUR'))}</strong>
                            </div>
                            ${promotionSummary}
                            <div class="${rootClass}__summary-row">
                                <span>${escapeHtml(labels.totalLabel || 'Total')}</span>
                                <strong>${escapeHtml(formatPrice(selectedCart ? selectedCart.total : 0, selectedCart ? selectedCart.currencyIso : 'EUR'))}</strong>
                            </div>
                        </div>
                        ${promotionControls}
                        <button type="button" class="${rootClass}__primary" data-ictech-add-selected>${escapeHtml(labels.addToSelectedCartLabel || 'Add to selected cart')}</button>
                        <div class="${rootClass}__actions">
                            <button type="button" class="${rootClass}__ghost" data-ictech-close>${escapeHtml(labels.continueShoppingLabel || 'Continue shopping')}</button>
                            <button type="button" class="${rootClass}__ghost" data-ictech-checkout>${escapeHtml(labels.checkoutLabel || 'Checkout')}</button>
                            <button type="button" class="${rootClass}__ghost" data-ictech-carts>${escapeHtml(labels.myCartsLabel || 'My carts')}</button>
                        </div>
                        <div class="${rootClass}__feedback" data-ictech-feedback></div>
                    </section>
                </div>
            </div>
        `;
    };

    const setFeedback = (message, type) => {
        const feedback = activeDialog.querySelector('[data-ictech-feedback]');

        if (!feedback) {
            return;
        }

        feedback.textContent = message || '';
        feedback.className = `${rootClass}__feedback${type ? ` is-${type}` : ''}`;
    };

    const refreshState = (state) => {
        activeContext.state = state;

        if (!activeContext.selectedCartId && Array.isArray(state.carts) && state.carts.length > 0) {
            activeContext.selectedCartId = state.activeCartId || state.carts[0].id;
        }

        renderDialog();
        bindDialogEvents();
    };

    const activateCart = async (cartId) => {
        activeContext.selectedCartId = cartId;

        const body = new FormData();
        body.append('cartId', cartId);

        const response = await request(activeContext.form.dataset.multiCartActivateUrl, body);
        refreshState(response.state || activeContext.state);
    };

    const createCart = async () => {
        if (!activeContext.state.canCreateCart) {
            const labels = activeContext.labels;
            const message = activeContext.state.createCartReason === 'limit_reached'
                ? (labels.createDisabledLimitLabel || 'You have reached the maximum number of carts.')
                : (labels.createDisabledUnavailableLabel || 'Cart creation is currently unavailable.');

            setFeedback(message, 'error');

            return;
        }

        const input = activeDialog.querySelector('[data-ictech-cart-name]');
        const name = input ? input.value.trim() : '';

        if (!name) {
            setFeedback(activeContext.labels.cartNameRequiredLabel || 'A cart name is required.', 'error');
            return;
        }

        const body = new FormData();
        body.append('name', name);

        const response = await request(activeContext.form.dataset.multiCartCreateUrl, body);
        refreshState(response.state || activeContext.state);
        activeContext.selectedCartId = response.cartId || activeContext.selectedCartId;
        await addToSelectedCart();
    };

    const addToSelectedCart = async () => {
        if (!activeContext.selectedCartId) {
            setFeedback(activeContext.labels.selectCartRequiredLabel || 'Please select a cart first.', 'error');
            return;
        }

        const body = new FormData();
        body.append('cartId', activeContext.selectedCartId);
        body.append('productId', activeContext.payload.productId);
        body.append('quantity', String(activeContext.payload.quantity));
        body.append('productName', activeContext.payload.productName);

        const response = await request(activeContext.form.dataset.multiCartAddUrl, body);
        refreshState(response.state || activeContext.state);
        setFeedback(activeContext.labels.addedSuccessLabel || response.message || 'The product was added to the selected cart.', 'success');
    };

    const updatePromotion = async () => {
        if (!activeContext.selectedCartId) {
            setFeedback(activeContext.labels.selectCartRequiredLabel || 'Please select a cart first.', 'error');
            return;
        }

        const input = activeDialog.querySelector('[data-ictech-promo-input]');
        const promotionCode = input instanceof HTMLInputElement ? input.value.trim() : '';

        if (promotionCode === '') {
            setFeedback(activeContext.labels.promoRequiredLabel || 'Please enter a promotion code.', 'error');
            return;
        }

        const body = new FormData();
        body.append('cartId', activeContext.selectedCartId);
        body.append('promotionCode', promotionCode);

        const response = await request(activeContext.form.dataset.multiCartPromotionUrl, body);
        refreshState(response.state || activeContext.state);
        setFeedback(
            response.message || (
                promotionCode === ''
                    ? (activeContext.labels.promoRemovedLabel || 'Promotion code removed.')
                    : (response.applied
                        ? (activeContext.labels.promoAppliedLabel || 'Promotion applied.')
                        : (activeContext.labels.promoSavedLabel || 'Promotion code saved.'))
            ),
            'success'
        );
    };

    const removePromotion = async () => {
        if (!activeContext.selectedCartId) {
            setFeedback(activeContext.labels.selectCartRequiredLabel || 'Please select a cart first.', 'error');
            return;
        }

        const body = new FormData();
        body.append('cartId', activeContext.selectedCartId);
        body.append('promotionCode', '');

        const response = await request(activeContext.form.dataset.multiCartPromotionUrl, body);
        refreshState(response.state || activeContext.state);
        setFeedback(response.message || activeContext.labels.promoRemovedLabel || 'Promotion code removed.', 'success');
    };

    const bindDialogEvents = () => {
        activeDialog.querySelectorAll('[data-ictech-close]').forEach((element) => {
            element.addEventListener('click', closeDialog);
        });

        activeDialog.querySelectorAll('[data-ictech-cart-select]').forEach((element) => {
            element.addEventListener('click', async () => {
                try {
                    await activateCart(element.getAttribute('data-ictech-cart-select'));
                } catch (error) {
                    setFeedback(error.message || activeContext.labels.switchCartErrorLabel || 'The selected cart could not be loaded.', 'error');
                }
            });
        });

        const dropdown = activeDialog.querySelector('[data-ictech-cart-dropdown]');

        if (dropdown) {
            dropdown.addEventListener('change', async () => {
                try {
                    await activateCart(dropdown.value);
                } catch (error) {
                    setFeedback(error.message || activeContext.labels.switchCartErrorLabel || 'The selected cart could not be loaded.', 'error');
                }
            });
        }

        const createButton = activeDialog.querySelector('[data-ictech-create-cart]');

        if (createButton) {
            createButton.addEventListener('click', async () => {
                try {
                    await createCart();
                } catch (error) {
                    setFeedback(error.message || activeContext.labels.createErrorLabel || 'The cart could not be created.', 'error');
                }
            });
        }

        const addButton = activeDialog.querySelector('[data-ictech-add-selected]');

        if (addButton) {
            addButton.addEventListener('click', async () => {
                try {
                    await addToSelectedCart();
                } catch (error) {
                    setFeedback(error.message || activeContext.labels.addErrorLabel || 'The product could not be added.', 'error');
                }
            });
        }

        const promoButton = activeDialog.querySelector('[data-ictech-promo-apply]');

        if (promoButton) {
            promoButton.addEventListener('click', async () => {
                try {
                    await updatePromotion();
                } catch (error) {
                    setFeedback(error.message || activeContext.labels.addErrorLabel || 'The promotion code could not be updated.', 'error');
                }
            });
        }

        const promoRemoveButton = activeDialog.querySelector('[data-ictech-promo-remove]');

        if (promoRemoveButton) {
            promoRemoveButton.addEventListener('click', async () => {
                try {
                    await removePromotion();
                } catch (error) {
                    setFeedback(error.message || activeContext.labels.addErrorLabel || 'The promotion code could not be updated.', 'error');
                }
            });
        }

        const checkoutButton = activeDialog.querySelector('[data-ictech-checkout]');

        if (checkoutButton) {
            checkoutButton.addEventListener('click', () => {
                if (!activeContext.selectedCartId) {
                    setFeedback(activeContext.labels.selectCartRequiredLabel || 'Please choose a cart first.', 'error');
                    return;
                }

                const template = activeContext.form.dataset.multiCartCheckoutUrlTemplate || '';
                window.location.href = template.replace('__cartId__', encodeURIComponent(activeContext.selectedCartId));
            });
        }

        const cartsButton = activeDialog.querySelector('[data-ictech-carts]');

        if (cartsButton) {
            cartsButton.addEventListener('click', () => {
                window.location.href = activeContext.form.dataset.multiCartCartsUrl;
            });
        }
    };

    const openDialog = (form, payload, state) => {
        closeDialog();
        ensureStyles();

        activeOverlay = document.createElement('div');
        activeOverlay.className = `${rootClass}-overlay`;
        activeOverlay.addEventListener('click', (event) => {
            if (event.target === activeOverlay) {
                closeDialog();
            }
        });

        activeDialog = document.createElement('div');
        activeDialog.className = rootClass;
        activeOverlay.appendChild(activeDialog);
        document.body.appendChild(activeOverlay);
        document.documentElement.classList.add('is-ictech-multi-cart-open');

        activeContext = {
            form,
            payload,
            state,
            labels: parseLabels(form),
            selectedCartId: state.activeCartId || (Array.isArray(state.carts) && state.carts.length > 0 ? state.carts[0].id : null),
        };

        renderDialog();
        bindDialogEvents();
    };

    document.addEventListener('submit', async (event) => {
        const form = event.target instanceof Element ? event.target.closest('form[data-ictech-multi-cart-add-to-cart="true"]') : null;

        if (!form) {
            return;
        }

        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();

        const payload = getPayload(form);

        if (!payload.productId) {
            return;
        }

        try {
            const state = await request(form.dataset.multiCartStateUrl);

            if (!state || !state.enabled) {
                return;
            }

            openDialog(form, payload, state);
        } catch (error) {
            // Keep the default flow suppressed and surface the issue in the console for debugging.
            console.error('ICTECH multi-cart inline flow failed:', error);
        }
    }, true);
})();
</script>
